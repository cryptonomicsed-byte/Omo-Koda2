# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your deps sources to.
/deps/

# Where third-party dependencies are built into (managed by Mix).
/priv/generated/

# Ignore .fetch files in case you wish to get them from a VCS.
/.fetch

# If the VM crashes, it generates a dump here.
erl_crash.dump

# Also ignore archive artifacts (important for deps).
*.ez

# Ignore package tarball (built via "mix hex.build").
yemoja-*.tar

# Temporary files (e.g. from tests).
/tmp/
