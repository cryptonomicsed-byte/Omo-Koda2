// oya/internal/transport/bridge.go
package transport

import (
    "context"
    "time"
    
    "google.golang.org/grpc"
    "github.com/omo-koda/oya/internal/rhythm"
)

// Bridge connects all Orishas
type OrishaBridge struct {
    // Clients to each service
    JuliaClient    osun.OsunClient      // gRPC to Julia
    ElixirClient   yemoja.YemojaClient  // gRPC to Elixir
    LispClient     obatala.ObatalaClient // gRPC to Lisp
    PythonClient   ogun.OgunClient      // gRPC to Python
    MoveClient     sango.SangoClient    // gRPC to Move (or REST)
    
    rhythmEngine   *rhythm.Engine
}

func (b *OrishaBridge) RouteThink(ctx context.Context, req *ThinkRequest) (*ThinkResponse, error) {
    // 1. Rhythm check (Ọya's domain)
    if b.rhythmEngine.IsInCooldown(req.AgentId) {
        return nil, status.Error(codes.ResourceExhausted, "cooldown active")
    }
    
    // 2. Route to Rust Steward (synchronous)
    stewardResult, err := b.RustSteward.Think(ctx, req)
    if err != nil {
        return nil, err
    }
    
    // 3. If LLM needed, route to Python (Ògún)
    if stewardResult.NeedsLlm {
        llmResult, err := b.PythonClient.Chat(ctx, &ogun.ChatRequest{
            SystemPrompt: stewardResult.SystemPrompt,
            UserMessage:  req.Prompt,
            IrisRouting:  stewardResult.IrisRouting,
            History:      req.History,
        })
        if err != nil {
            return nil, err
        }
        stewardResult.Content = llmResult.Content
    }
    
    // 4. Update rhythm
    b.rhythmEngine.RecordThought(req.AgentId)
    
    return stewardResult, nil
}

func (b *OrishaBridge) RouteMemoryReconstruct(ctx context.Context, req *MemoryRequest) (*MemoryResponse, error) {
    // Julia (Ọ̀ṣun) handles all memory operations
    return b.JuliaClient.Reconstruct(ctx, &osun.ReconstructRequest{
        AgentId: req.AgentId,
        Query:   req.Query,
        Emotion: req.Emotion,
    })
}

func (b *OrishaBridge) RouteHermetic(ctx context.Context, req *HermeticRequest) (*HermeticResponse, error) {
    // Lisp (Ọbàtálá) handles deep ethics
    return b.LispClient.Evaluate(ctx, &obatala.EvaluateRequest{
        Intent:      req.Intent,
        Action:      req.Action,
        SessionState: req.SessionState,
    })
}
