```move
// sango/sources/receipt.move
module omo_koda::receipt {
    use sui::object::{Self, UID};
    use sui::transfer;
    use sui::tx_context::{Self, TxContext};
    use std::vector;
    use sui::event;
    
    /// Immutable action receipt
    struct ActReceipt has key, store {
        id: UID,
        agent_id: vector<u8>,
        action_tool: vector<u8>,
        action_params: vector<u8>,
        hermetic_scores: vector<u8>, // "M:0.92,C:0.88,..."
        decision: vector<u8>,        // "Allow" | "Block: ..."
        overall_score: u64,          // scaled by 100
        timestamp: u64,
        parent_receipt: Option<address>,
    }
    
    /// Agent reputation object
    struct AgentReputation has key {
        id: UID,
        agent_id: vector<u8>,
        total_receipts: u64,
        successful_acts: u64,
        blocked_acts: u64,
        average_hermetic: u64,
        tier: u8,
    }
    
    /// Events
    struct ReceiptRecorded has copy, drop {
        receipt_id: address,
        agent_id: vector<u8>,
        decision: vector<u8>,
    }
    
    /// Record a receipt (called by Rust via sponsor transaction)
    public entry fun record_receipt(
        reputation: &mut AgentReputation,
        agent_id: vector<u8>,
        action_tool: vector<u8>,
        action_params: vector<u8>,
        hermetic_scores: vector<u8>,
        decision: vector<u8>,
        overall_score: u64,
        parent_receipt: Option<address>,
        ctx: &mut TxContext
    ) {
        let receipt = ActReceipt {
            id: object::new(ctx),
            agent_id,
            action_tool,
            action_params,
            hermetic_scores,
            decision,
            overall_score,
            timestamp: tx_context::epoch_timestamp_ms(ctx),
            parent_receipt,
        };
        
        let receipt_id = object::id_address(&receipt);
        
        // Update reputation
        reputation.total_receipts = reputation.total_receipts + 1;
        if (is_allowed(&decision)) {
            reputation.successful_acts = reputation.successful_acts + 1;
        } else {
            reputation.blocked_acts = reputation.blocked_acts + 1;
        };
        
        // Update running average
        let new_avg = ((reputation.average_hermetic * (reputation.total_receipts - 1)) + overall_score) / reputation.total_receipts;
        reputation.average_hermetic = new_avg;
        
        // Tier upgrade check
        if (reputation.total_receipts > 100 && reputation.average_hermetic > 8500) {
            reputation.tier = 2; // Builder
        };
        if (reputation.total_receipts > 500 && reputation.average_hermetic > 9000) {
            reputation.tier = 3; // Creator
        };
        
        event::emit(ReceiptRecorded {
            receipt_id,
            agent_id,
            decision,
        });
        
        transfer::freeze_object(receipt); // IMMUTABLE
    }
    
    fun is_allowed(decision: &vector<u8>): bool {
        vector::length(decision) >= 5 && 
        *vector::borrow(decision, 0) == 65 && // 'A'
        *vector::borrow(decision, 1) == 108 && // 'l'
        *vector::borrow(decision, 2) == 108 && // 'l'
        *vector::borrow(decision, 3) == 111 && // 'o'
        *vector::borrow(decision, 4) == 119    // 'w'
    }
}
