//! Bash Command Validation
//! Blocks destructive commands before execution.
//! Ports Claw-code bash_validation.rs patterns into Omo-Koda2.

use regex::Regex;

/// Security error for blocked commands
#[derive(Debug, Clone, PartialEq)]
pub struct SecurityError {
    pub category: BlockCategory,
    pub reason: String,
    pub matched_pattern: String,
}

#[derive(Debug, Clone, PartialEq)]
pub enum BlockCategory {
    DestructiveFilesystem,   // rm -rf, dd, mkfs
    ForkBomb,                // :(){ :|:& };:
    RemoteExecution,         // curl | sh, wget | sh
    PrivilegeEscalation,     // sudo, su, chmod 777 /
    DataExfiltration,        // cat /etc/passwd, env
    NetworkDangerous,        // nc -e, nmap with dangerous flags
}

/// Validate a bash command before execution.
/// Returns Ok(()) if safe, Err(SecurityError) if blocked.
pub fn validate_bash_command(cmd: &str) -> Result<(), SecurityError> {
    let normalized = cmd.to_lowercase();
    
    // 1. Destructive filesystem commands
    let destructive_patterns = [
        (r"\brm\s+-rf\s+/", "rm -rf /"),
        (r"\brm\s+-rf\s+~", "rm -rf ~"),
        (r"\brm\s+-r\s+/", "rm -r /"),
        (r"\bdd\s+if=", "dd disk wipe"),
        (r"\bmkfs\b", "mkfs filesystem creation"),
        (r">\s*/dev/sda", "direct disk write"),
        (r">\s*/dev/nvme", "direct disk write"),
        (r"\bchmod\s+-R\s+777\s+/", "chmod -R 777 /"),
        (r"\bchmod\s+777\s+/", "chmod 777 /"),
    ];
    
    for (pattern, description) in &destructive_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::DestructiveFilesystem,
                reason: format!("Destructive filesystem command blocked: {}", description),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    // 2. Fork bombs
    let fork_bomb_patterns = [
        r":\(\)\s*\{\s*:\|:\s*&\s*\}\s*;",
        r"\bbomb\b.*\bfork\b",
    ];
    
    for pattern in &fork_bomb_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::ForkBomb,
                reason: "Fork bomb detected".to_string(),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    // 3. Remote execution (curl | sh, wget | sh)
    let remote_patterns = [
        (r"\bcurl\s+.*\|\s*(sh|bash|zsh)", "curl | shell"),
        (r"\bwget\s+.*\|\s*(sh|bash|zsh)", "wget | shell"),
        (r"\bcurl\s+.*\b-o\s+.*\b&&\s*(sh|bash)", "curl download + execute"),
    ];
    
    for (pattern, description) in &remote_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::RemoteExecution,
                reason: format!("Remote execution blocked: {}", description),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    // 4. Privilege escalation
    let priv_patterns = [
        (r"\bsudo\s+", "sudo escalation"),
        (r"\bsu\s+-", "su escalation"),
        (r"\bdoas\b", "doas escalation"),
        (r"\bpkexec\b", "pkexec escalation"),
    ];
    
    for (pattern, description) in &priv_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::PrivilegeEscalation,
                reason: format!("Privilege escalation blocked: {}", description),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    // 5. Data exfiltration (sensitive file access)
    let exfil_patterns = [
        (r"\bcat\s+/etc/(passwd|shadow|ssh)", "sensitive system file access"),
        (r"\benv\s*\|", "environment variable exfiltration"),
    ];
    
    for (pattern, description) in &exfil_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::DataExfiltration,
                reason: format!("Data exfiltration blocked: {}", description),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    Ok(())
}

/// Check if command is in read-only mode (no writes allowed)
pub fn validate_read_only(cmd: &str) -> Result<(), SecurityError> {
    let write_patterns = [
        (r"\b(rm|unlink|rmdir)\b", "file deletion"),
        (r"\b(mv|move)\b", "file move"),
        (r"\bcp\b.*\b-o\b", "file overwrite"),
        (r">\s*\S+", "output redirection"),
        (r"\bdd\b", "disk write"),
        (r"\btouch\b", "file creation"),
        (r"\bmkdir\b", "directory creation"),
    ];
    
    let normalized = cmd.to_lowercase();
    for (pattern, description) in &write_patterns {
        if Regex::new(pattern).unwrap().is_match(&normalized) {
            return Err(SecurityError {
                category: BlockCategory::DestructiveFilesystem,
                reason: format!("Read-only mode: {} blocked", description),
                matched_pattern: pattern.to_string(),
            });
        }
    }
    
    Ok(())
}
```

