# ogun/src/tools/llm_provider.py
import os
import asyncio
from typing import Optional, List, Dict
from dataclasses import dataclass
import aiohttp

@dataclass
class IrisRouting:
    profile: str
    max_tokens: int
    temperature: float
    style_injection: str
    warmth_boost: bool

@dataclass
class SomaContext:
    system_prompt: str
    lpm: Optional[dict]
    emotion_description: str
    recent_memories: List[str]

class LlmProvider:
    """Abstracted LLM interface with IRIS routing support"""
    
    def __init__(self, config: dict):
        self.api_key = config['api_key']
        self.base_url = config['base_url']
        self.model = config['model']
        self.is_anthropic = 'anthropic.com' in self.base_url
        
    async def chat(
        self,
        soma_context: SomaContext,
        user_message: str,
        routing: IrisRouting,
        history: List[Dict[str, str]]
    ) -> str:
        """Execute chat with full SOMA + IRIS context"""
        
        # Build system prompt with IRIS injection
        system = f"""{soma_context.system_prompt}

## IRIS ROUTING: {routing.profile.upper()}
Response style: {routing.style_injection}
Max depth: {routing.profile}
"""
        if routing.warmth_boost:
            system += "\nConnection is high — let warmth through naturally."
        
        # Add SOMA context
        if soma_context.emotion_description:
            system += f"\n\n## EMOTIONAL STATE\n{soma_context.emotion_description}"
        
        if soma_context.lpm:
            system += f"\n\n## LPM\n{soma_context.lpm}"
        
        # Trim history (Droidclaw pattern)
        messages = history[-20:] if len(history) > 20 else history
        messages.append({"role": "user", "content": user_message})
        
        # Call appropriate API
        if self.is_anthropic:
            return await self._anthropic(system, messages, routing)
        return await self._openai(system, messages, routing)
    
    async def raw_chat(self, prompt: str) -> str:
        """For internal operations (SOMA consolidation, learning, reflection)"""
        messages = [{"role": "user", "content": prompt}]
        return await self._openai(None, messages, IrisRouting("balanced", 2048, 0.7, "", False))
    
    async def _openai(self, system: Optional[str], messages: List[dict], routing: IrisRouting):
        headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {self.api_key}"
        }
        body = {
            "model": self.model,
            "messages": ([{"role": "system", "content": system}] if system else []) + messages,
            "max_tokens": routing.max_tokens,
            "temperature": routing.temperature
        }
        
        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.base_url}/chat/completions",
                headers=headers,
                json=body
            ) as resp:
                data = await resp.json()
                return data['choices'][0]['message']['content']
    
    async def _anthropic(self, system: Optional[str], messages: List[dict], routing: IrisRouting):
        headers = {
            "Content-Type": "application/json",
            "x-api-key": self.api_key,
            "anthropic-version": "2023-06-01"
        }
        body = {
            "model": self.model or "claude-sonnet-4-6",
            "max_tokens": routing.max_tokens,
            "messages": messages
        }
        if system:
            body["system"] = system
            
        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.base_url}/messages",
                headers=headers,
                json=body
            ) as resp:
                data = await resp.json()
                return data['content'][0]['text']
```

