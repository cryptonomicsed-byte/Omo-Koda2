Why Omo-Koda2 needs it: Currently Omo-Koda2 has `SessionState` with cooldowns but no emotional state tracking. The Hermetic ethics gate evaluates actions but doesn't know the user's emotional state.

Porting strategy: New module `omokoda-core/src/session/emotion.rs`.

```rust
// omokoda-core/src/session/emotion.rs
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionState {
    pub energy: f32,      // 0=exhausted, 1=alert
    pub tension: f32,     // 0=calm, 1=frustrated
    pub connection: f32,  // 0=distant, 1=close
    pub focus: f32,       // 0=scattered, 1=deep
    pub updated_at: DateTime<Utc>,
}

impl EmotionState {
    pub fn update_from_message(&mut self, message: &str, role: Role) {
        if role == Role::User {
            let text = message.to_lowercase();
            
            // Frustration signals
            let frustration = ["wtf", "broken", "fix", "wrong", "stop", "stupid", "useless", "hate", "frustrated"];
            for word in &frustration {
                if text.contains(word) { self.tension = (self.tension + 0.1).min(1.0); }
            }
            
            // Warmth signals
            let warmth = ["thanks", "good", "love", "great", "nice", "perfect", "appreciate"];
            for word in &warmth {
                if text.contains(word) { 
                    self.tension = (self.tension - 0.1).max(0.0);
                    self.connection = (self.connection + 0.05).min(1.0);
                }
            }
            
            // Depth signals
            let deep = ["why", "how", "feel", "want", "believe", "vision", "dream"];
            for word in &deep {
                if text.contains(word) { self.focus = (self.focus + 0.1).min(1.0); }
            }
            
            // Message length = engagement
            if text.len() > 100 { self.focus = (self.focus + 0.05).min(1.0); }
            if text.len() < 10 { self.focus = (self.focus - 0.05).max(0.0); }
        }
        
        // Natural decay
        self.tension *= 0.95;
        self.focus = self.focus * 0.98 + 0.5 * 0.02;
        self.connection *= 0.99;
        self.updated_at = Utc::now();
    }
    
    pub fn update_from_sensors(&mut self, battery: Option<u8>, temp: Option<f32>, hour: u8) {
        if let Some(b) = battery {
            self.energy = match b {
                0..=15 => 0.1,
                16..=30 => 0.3,
                31..=50 => 0.6,
                _ => 0.9,
            };
        }
        
        if let Some(t) = temp {
            if t > 40.0 { self.tension = (self.tension + 0.2).min(1.0); }
        }
        
        match hour {
            1..=5 => self.energy = self.energy.min(0.3),
            23 | 0 => self.energy = self.energy.min(0.5),
            9..=18 => self.energy = self.energy.max(0.6),
            _ => {}
        }
    }
    
    pub fn describe(&self) -> String {
        let mut lines = vec![];
        if self.energy < 0.3 { lines.push("exhausted — keep responses short and raw"); }
        else if self.energy < 0.6 { lines.push("low energy — be efficient"); }
        else { lines.push("alert and present"); }
        
        if self.tension > 0.6 { lines.push("tension high — tread carefully"); }
        else if self.tension > 0.3 { lines.push("mild tension in the air"); }
        
        if self.connection > 0.7 { lines.push("close — real conversation, not commands"); }
        if self.focus > 0.7 { lines.push("deep focus mode — this conversation has weight"); }
        
        lines.join(". ")
    }
}
