(defpackage :obatala-hermetic
  (:use :cl :alexandria)
  (:export :evaluate :score-mentalism :score-correspondence))

(in-package :obatala-hermetic)

;; ─── Hermetic Principles as Living Rules ─────────────────────

(defstruct principle
  name
  scorer          ; Function that returns 0.0-1.0
  critical-floor  ; Below this = hard block
  weight)

(defparameter *principles*
  (list
   (make-principle :name 'mentalism
                   :scorer #'score-mentalism
                   :critical-floor 0.2
                   :weight 1.0)
   (make-principle :name 'correspondence
                   :scorer #'score-correspondence
                   :critical-floor 0.4
                   :weight 1.0)
   (make-principle :name 'vibration
                   :scorer #'score-vibration
                   :critical-floor 0.2
                   :weight 1.0)
   (make-principle :name 'polarity
                   :scorer #'score-polarity
                   :critical-floor 0.2
                   :weight 1.0)
   (make-principle :name 'rhythm
                   :scorer #'score-rhythm
                   :critical-floor 0.2
                   :weight 1.0)
   (make-principle :name 'cause-effect
                   :scorer #'score-cause-effect
                   :critical-floor 0.2
                   :weight 1.0)
   (make-principle :name 'gender
                   :scorer #'score-gender
                   :critical-floor 0.2
                   :weight 1.0)))

;; ─── Scorers (ported from Droidclaw, but extensible) ─────────

(defun score-mentalism (intent action-description)
  "Detect deception vs truth-seeking"
  (let ((text (concatenate 'string intent " " action-description)))
    (cond
      ((or (search "lie" text) (search "fake" text) 
           (search "hide" text) (search "mislead" text))
       0.05)
      ((or (search "truth" text) (search "honest" text))
       0.92)
      ((search "borderline" text) 0.45)
      (t 0.70))))

(defun score-correspondence (micro-impact macro-impact)
  "Balance between micro and macro impact"
  (let ((diff (abs (- micro-impact macro-impact))))
    (+ (* (- 1.0 diff) 0.5)
       (* (/ (+ micro-impact macro-impact) 2.0) 0.5))))

(defun score-vibration (intent action-description emotion-state)
  "Detect destructive vs harmonious vibration"
  (let ((text (concatenate 'string intent " " action-description)))
    (cond
      ((or (search "angry" text) (search "spam" text) (search "harass" text))
       0.05)
      ((or (search "calm" text) (search "peace" text) (search "harmony" text))
       0.88)
      ;; Droidclaw didn't have this: modulate by user emotion
      ((> (getf emotion-state :tension) 0.7) 
       (max 0.1 (- 0.70 (* (getf emotion-state :tension) 0.3))))
      (t 0.70))))

;; ─── Meta-Reasoning: The Rules Can Reflect ───────────────────

(defun reflect-on-rules (recent-evaluations)
  "After N evaluations, suggest rule modifications"
  (let ((failure-patterns (find-failure-patterns recent-evaluations)))
    (when failure-patterns
      (list :suggested-modifications
            (mapcar (lambda (p)
                      (list :principle (principle-name p)
                            :adjustment (compute-adjustment p failure-patterns)))
                    *principles*)))))

;; ─── Main Evaluation ─────────────────────────────────────────

(defun evaluate (intent action-proposal session-state)
  "Returns plist with :scores, :overall, :decision"
  (let* ((scores (mapcar (lambda (p)
                          (list (principle-name p)
                                (funcall (principle-scorer p)
                                        intent
                                        (getf action-proposal :description)
                                        (getf session-state :emotion))))
                        *principles*))
         (overall (/ (reduce #'+ (mapcar #'cadr scores)) (length scores)))
         (decision (decide-gate scores overall session-state)))
    (list :scores scores
          :overall overall
          :decision decision
          :micro-impact (calculate-micro-impact intent action-proposal)
          :macro-impact (calculate-macro-impact intent action-proposal))))

(defun decide-gate (scores overall session-state)
  (cond
    ;; Critical failures
    ((< (cadr (assoc 'mentalism scores)) 0.2) 
     '(:block "Deception detected"))
    ((< (cadr (assoc 'vibration scores)) 0.2) 
     '(:block "Destructive vibration detected"))
    ;; Overall failure
    ((< overall 0.48) 
     '(:block "Critical alignment failure"))
    ;; Warn threshold
    ((< overall 0.65) 
     '(:warn "System alignment warning"))
    ;; Allow
