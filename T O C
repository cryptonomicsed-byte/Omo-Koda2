use crate::errors::OsoError;

#[derive(Clone)]
pub struct Council {
    elders: Vec<String>,
    quorum: usize,
}

impl Council {
    pub fn new(elders: Vec<String>, quorum: usize) -> Self {
        Self { elders, quorum }
    }
    pub fn check_quorum(&self, present_sigs: &[String]) -> Result<(), OsoError> {
        let mut count = 0usize;
        for s in present_sigs {
            if self.elders.iter().any(|e| e == s) { count += 1; }
        }
        if count >= self.quorum { Ok(()) } else { Err(OsoError::CouncilQuorum) }
    }
}


