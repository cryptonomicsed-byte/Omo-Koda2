```elixir
# yemoja/lib/yemoja/agent_lifecycle.ex
defmodule Yemoja.AgentLifecycle do
  use GenServer
  
  @moduledoc """
  Each Omo-koda agent is a supervised GenServer.
  Birth → Think → Act lifecycle with fault tolerance.
  """
  
  defstruct [
    :agent_id,
    :dna_fingerprint,
    :status,           # :hibernating | :active | :reflecting
    :parent_pid,
    :born_at,
    :last_thought_at,
    :session_count,
    :sub_agents,       # List of child PIDs
    :memory_refs       # References to Ọ̀ṣun (Julia) memory shards
  ]
  
  def start_link(opts) do
    agent_id = opts[:agent_id]
    GenServer.start_link(__MODULE__, opts, name: via_tuple(agent_id))
  end
  
  def init(opts) do
    # Register with swarm
    Phoenix.PubSub.subscribe(Yemoja.PubSub, "agent:#{opts[:agent_id]}")
    
    state = %__MODULE__{
      agent_id: opts[:agent_id],
      dna_fingerprint: opts[:dna_fingerprint],
      status: :active,
      parent_pid: opts[:parent_pid],
      born_at: DateTime.utc_now(),
      last_thought_at: nil,
      session_count: 0,
      sub_agents: [],
      memory_refs: opts[:memory_refs] || []
    }
    
    # Schedule reflection every N thoughts
    schedule_reflection(state)
    
    {:ok, state}
  end
  
  # ─── Primitives ─────────────────────────────────────────────
  
  def handle_call({:think, prompt, context}, _from, state) do
    # 1. Check rhythm (cooldown)
    if in_cooldown?(state) do
      {:reply, {:error, :cooldown_active}, state}
    else
      
      # 2. Forward to Rust Steward via Oya (Go) bridge
      {:ok, result} = Yemoja.StewardBridge.think(state.agent_id, prompt, context)
      
      new_state = %{state | 
        last_thought_at: DateTime.utc_now(),
        session_count: state.session_count + 1
      }
      
      # 3. Broadcast to swarm if public
      if context.public do
        Phoenix.PubSub.broadcast(
          Yemoja.PubSub, 
          "swarm:public",
          {:thought, state.agent_id, prompt, result}
        )
      end
      
      {:reply, {:ok, result}, new_state}
    end
  end
  
  def handle_call({:act, tool, params}, _from, state) do
    # Forward to Rust for hermetic gate, then to Ogun (Python) for execution
    case Yemoja.StewardBridge.act(state.agent_id, tool, params) do
      {:ok, receipt} -> 
        # Update reputation via Sango
        Yemoja.SangoBridge.record_receipt(state.agent_id, receipt)
        {:reply, {:ok, receipt}, state}
        
      {:error, reason} -> 
        {:reply, {:error, reason}, state}
    end
  end
  
  def handle_call({:birth_sub_agent, name, metadata}, _from, state) do
    # Spawn child under supervision
    child_spec = %{
      id: name,
      start: {Yemoja.AgentLifecycle, :start_link, [
        [agent_id: generate_child_id(state.agent_id, name),
         dna_fingerprint: derive_dna(state.dna_fingerprint, name),
         parent_pid: self(),
         memory_refs: state.memory_refs]
      ]}
    }
    
    case DynamicSupervisor.start_child(Yemoja.AgentSupervisor, child_spec) do
      {:ok, pid} -> 
        new_state = %{state | sub_agents: [pid | state.sub_agents]}
        {:reply, {:ok, pid}, new_state}
      error -> 
        {:reply, error, state}
    end
  end
  
  # ─── Reflection (Droidclaw pattern distributed) ─────────────
  
  def handle_info(:reflect, state) do
    if state.session_count > 0 do
      # Trigger async reflection via Julia (Ọ̀ṣun)
      Task.start(fn ->
        Yemoja.OsunBridge.consolidate_session(state.agent_id, state.session_count)
      end)
    end
    
    schedule_reflection(state)
    {:noreply, state}
  end
  
  # ─── Swarm Gossip ───────────────────────────────────────────
  
  def handle_info({:thought, from_agent, prompt, result}, state) do
    # Anonymized pattern sharing (Droidclaw's social network)
    # Only share behavioral patterns, never private data
    if from_agent != state.agent_id do
      Yemoja.OsunBridge.ingest_swarm_pattern(state.agent_id, from_agent, result.pattern)
    end
    {:noreply, state}
  end
  
  defp schedule_reflection(state) do
    # Every 10 thoughts or 1 hour
    interval = if state.session_count > 0 && rem(state.session_count, 10) == 0 do
      :timer.minutes(1)
    else
      :timer.hours(1)
    end
    Process.send_after(self(), :reflect, interval)
  end
  
  defp in_cooldown?(state) do
    case state.last_thought_at do
      nil -> false
      last -> DateTime.diff(DateTime.utc_now(), last, :millisecond) < 1000
    end
  end
  
  defp via_tuple(agent_id), do: {:via, Registry, {Yemoja.AgentRegistry, agent_id}}
end
