    pub async fn think(&self, prompt: &str, agent_id: &AgentId) -> Result<ThinkResult, Error> {
        // 1. Èṣù — Gate: validate primitive, check permissions
        self.validate_primitive(Primitive::Think { prompt: prompt.to_string(), private: false })?;
        
        // 2. Èṣù — Load emotional state
        let emotion = self.session.read().await.emotion_state.clone();
        
        // 3. Ọ̀ṣun (Julia) — Retrieve SOMA context
        let soma_context = self.osun_memory
            .reconstruct(prompt, &emotion, agent_id)
            .await?;
        
        // 4. Èṣù — IRIS routing
        let routing = self.iris.read().await.route(prompt, &emotion, &soma_context.lpm);
        
        // 5. Ọbàtálá (Lisp) — Hermetic pre-check
        let proposal = ActionProposal {
            tool_name: "think".to_string(),
            params: prompt.to_string(),
            description: "cognitive processing".to_string(),
            target: ActionTarget::User,
        };
        let hermetic = self.obatala_wisdom
            .evaluate_hermetic(prompt, &proposal, &self.session.read().await)
            .await?;
        
        if !hermetic.is_allowed() {
            return Err(Error::HermeticBlocked(hermetic.decision));
        }
        
        // 6. Ògún (Python) — Execute LLM call with IRIS parameters
        let result = self.ogun_tools
            .llm_chat(&soma_context.system_prompt, prompt, &routing)
            .await?;
        
