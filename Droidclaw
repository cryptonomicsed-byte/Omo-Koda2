    needs::Vector{String}
    foresight::Vector{String}
    growth::Vector{String}
end

"Score a MemCell for retrieval — Julia vectorized operations"
function score_retrieval(cell::MemCell, now::DateTime, emotion::EmotionTrace)
    age_hours = (now - cell.timestamp).value / 3600000.0f0
    recency = 0.995f0 ^ age_hours
    importance = cell.importance
    emotion_score = cell.emotion.score
    
    emotion_boost = 0.0f0
    if emotion.tension > 0.5 && cell.emotion.tension > 0.5
        emotion_boost += 0.15f0
    end
    if emotion.connection > 0.6 && cell.emotion.connection > 0.6
        emotion_boost += 0.1f0
    end
    
    activation_boost = min(0.2f0, cell.activations * 0.02f0)
    
    (recency * 0.25f0) + (importance * 0.35f0) + (emotion_score * 0.25f0) + emotion_boost + activation_boost
end

"Batch score all cells — vectorized"
function score_all(cells::Vector{MemCell}, now::DateTime, emotion::EmotionTrace)
    scores = Float32[]
    for cell in cells
        push!(scores, score_retrieval(cell, now, emotion))
    end
    scores
end

"Reconstructive recollection — assemble exactly what's needed"
function reconstruct(cells::Vector{MemCell}, scenes::Dict{String,MemScene}, 
                     lpm::LPM, query::String, emotion::EmotionTrace)
    lines = String[]
    
    # 1. Foresight
    if !isempty(lpm.foresight)
        push!(lines, "## PREDICTED NEEDS")
        for f in lpm.foresight[1:min(3, end)]
            push!(lines, "- $f")
        end
    end
    
    # 2. Relevant patterns
    query_words = filter(w -> length(w) > 3, split(lowercase(query)))
    relevant_patterns = filter(p -> any(w -> occursin(w, lowercase(p)), query_words), lpm.patterns)
    if !isempty(relevant_patterns)
        push!(lines, "## RELEVANT PATTERNS")
        for p in relevant_patterns[1:min(3, end)]
            push!(lines, "- $p")
        end
    end
    
    # 3. Triggers if tension high
    if emotion.tension > 0.4 && !isempty(lpm.triggers)
        push!(lines, "## ACTIVE TRIGGERS")
        for t in lpm.triggers[1:min(3, end)]
            push!(lines, "- $t")
        end
    end
    
    # 4. Active MemScenes
    active_scenes = sort(collect(values(scenes)), by=s->s.strength, rev=true)
    active_scenes = filter(s->s.strength > 1, active_scenes)
    if !isempty(active_scenes)
        push!(lines, "## ACTIVE THEMES")
        for s in active_scenes[1:min(3, end)]
            push!(lines, "- $(s.theme): $(s.summary)")
        end
    end
    
    # 5. Core identity
    if !isempty(lpm.identity)
        push!(lines, "## CORE IDENTITY")
        for i in lpm.identity[1:min(5, end)]
            push!(lines, "- $i")
        end
    end
    
    join(lines, "\n")
end

