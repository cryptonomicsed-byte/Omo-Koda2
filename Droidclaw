5. Agent Loop with Tool Parsing & Reflection (`src/core/loop.js`)

What it is: A ReAct-style loop that:
- Parses `<tool>name</tool>{"arg": "value"}` syntax from LLM output
- Executes tools with timeout (10s)
- Handles errors gracefully (tracks consecutive failures)
- Async reflection every N conversations (journal entries)
- Max iteration guard (5)

Why Omo-Koda2 needs it: Currently Omo-Koda2 has tool execution in `execution/mod.rs` but no conversation loop with reflection. The `act` primitive is one-shot.

Porting strategy: Extend `omokoda-core/src/interpreter/mod.rs` (Steward) with loop logic.

```rust
// omokoda-core/src/interpreter/loop.rs
pub struct AgentLoop {
    max_iterations: usize,
    tool_timeout: Duration,
}

impl AgentLoop {
    pub async fn run(
        &self,
        user_message: &str,
        engine: &mut Steward,
        registry: &ToolRegistry,
        context: &ExecutionContext,
    ) -> Result<String, String> {
        let mut iteration = 0;
        let mut had_error = false;
        
        // Initial think + act
        engine.pulse(user_message, Role::User);
        let mut raw = engine.chat(user_message).await?;
        let mut tools = self.parse_tools(&raw);
        let mut reply = self.clean_reply(&raw);
        
        if tools.is_empty() {
            engine.record_success();
            self.maybe_reflect(engine).await;
            return Ok(reply);
        }
        
        // Tool execution loop
        while !tools.is_empty() && iteration < self.max_iterations {
            iteration += 1;
            let mut tool_results = String::new();
            
            for tool in &tools {
                match tokio::time::timeout(
                    self.tool_timeout,
                    registry.execute(&tool.name, &tool.params, context.clone(), &policy, None)
                ).await {
                    Ok(Ok((result, _))) => {
                        tool_results.push_str(&format!("[{}]: {}\n", tool.name, &result[..result.len().min(1000)]));
                        engine.record_success();
                    }
                    Ok(Err(e)) => {
                        tool_results.push_str(&format!("[{}] error: {}\n", tool.name, e));
                        engine.record_failure();
                        had_error = true;
                    }
                    Err(_) => {
                        tool_results.push_str(&format!("[{}] error: timed out\n", tool.name));
                        engine.record_failure();
                        had_error = true;
                    }
                }
            }
            
            // Feed results back
            raw = engine.chat(&format!("[tool results]\n{}\nrespond to user now.", tool_results)).await?;
            tools = self.parse_tools(&raw);
            reply = self.clean_reply(&raw);
        }
        
        if iteration >= self.max_iterations && reply.is_empty() {
            reply = "hit iteration limit — something got stuck. try again.".to_string();
        }
        
        self.maybe_reflect(engine).await;
        Ok(reply)
    }
    
    fn parse_tools(&self, text: &str) -> Vec<ToolCall> {
        // Regex-based parsing of <tool>name</tool>{...} pattern
        let re = Regex::new(r"<tool>(\w+)</tool>(\{.*?\})").unwrap();
        re.captures_iter(text)
            .filter_map(|cap| {
                let name = cap.get(1)?.as_str().to_string();
                let args = serde_json::from_str(cap.get(2)?.as_str()).ok()?;
                Some(ToolCall { name, args })
            })
            .collect()
    }
    
    async fn maybe_reflect(&self, engine: &mut Steward) {
        if !engine.should_reflect() { return; }
        engine.mark_reflected();
        
        let history = engine.get_history();
        let prompt = format!(
            "Reflect on recent conversations.\n\n{}\n\n\
             Write a short journal entry — what worked, what failed, what you learned. \
             Be honest. No report format, just your thoughts.",
            history
        );
        
        if let Ok(reflection) = engine.raw_chat(&prompt).await {
            if reflection.len() > 50 {
                engine.append_journal(&reflection);
            }
        }
    }
}
```

