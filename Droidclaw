// ase/src/lib.rs (WASM module)
use wasm_bindgen::prelude::*;

#[wasm_bindgen]
pub struct AseAgent {
    agent_id: String,
    emotion_state: JsValue,
    memory_cache: JsValue,
}

#[wasm_bindgen]
impl AseAgent {
    #[wasm_bindgen(constructor)]
    pub fn new(agent_id: String, dna_seed: String) -> Self {
        Self {
            agent_id,
            emotion_state: JsValue::NULL,
            memory_cache: JsValue::NULL,
        }
    }
    
    /// birth — runs entirely in WASM
    #[wasm_bindgen]
    pub fn birth(&mut self, name: String, metadata: JsValue) -> Result<JsValue, JsValue> {
        // Generate identity locally
        let identity = generate_identity(&name, &metadata);
        Ok(serde_wasm_bindgen::to_value(&identity).unwrap())
    }
    
    /// think — lightweight, calls remote Èṣù only for heavy lifting
    #[wasm_bindgen]
    pub async fn think(&self, prompt: String, context: JsValue) -> Result<JsValue, JsValue> {
        // 1. Local IRIS routing (cached rules)
        let routing = self.local_iris_route(&prompt);
        
        // 2. If online, sync with Èṣù
        if self.is_online() {
            let remote = self.call_steward_think(&prompt).await?;
            Ok(remote)
        } else {
            // 3. Offline mode: use cached SOMA + local LLM (ONNX/WASM)
            let local = self.offline_think(&prompt, &routing).await?;
            Ok(local)
        }
    }
    
    /// act — execute tools in WASM sandbox
    #[wasm_bindgen]
    pub async fn act(&self, tool: String, params: JsValue) -> Result<JsValue, JsValue> {
        match tool.as_str() {
            "read_file" => self.wasm_read_file(params).await,
            "write_file" => self.wasm_write_file(params).await,
            "web_search" => self.wasm_web_search(params).await,
            _ => Err(JsValue::from_str("Unknown tool"))
        }
    }
    
    fn local_iris_route(&self, prompt: &str) -> IrisRouting {
        // Simplified IRIS for WASM (no LLM call)
        let len = prompt.len();
        if len < 15 {
            IrisRouting::reflex()
        } else if prompt.contains("error") || prompt.contains("debug") {
            IrisRouting::sharp()
        } else if prompt.contains("feel") || prompt.contains("sad") {
            IrisRouting::gentle()
        } else if len > 150 {
            IrisRouting::deep()
        } else {
            IrisRouting::balanced()
        }
    }
}
