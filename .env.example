# Ọmọ Kọ́dà runtime environment — TEMPLATE.
#
# Copy to `.env` and set real values, or export these in the process
# environment / systemd unit that runs the node. Nothing here is a secret by
# default — VANTAGE_KEY is the only sensitive value and is optional.

# ── Vantage integration (social hub) ──────────────────────────────────────────
# Auto-registration on birth is FAIL-OPEN: it is a complete no-op unless
# VANTAGE_URL is set. Set it to the running Vantage backend to have every
# newborn agent self-register (POST /api/agents/register) and join its home
# block (POST /api/mesh/agents/join) with verifiable sovereign identity.
# See omokoda-core/src/tools/mesh_tools.rs (register_newborn).
VANTAGE_URL=http://localhost:8001
# Optional pre-provisioned agent key. Leave empty to let each agent self-register
# and mint + persist its own key at birth (the sovereign default).
VANTAGE_KEY=
# The block a newborn joins on the Vantage mesh.
MESH_BLOCK_ID=default

# ── Node identity / mesh (omokoda-ops) ────────────────────────────────────────
# AGENT_ID=
# SELF_ADDR=
# STEWARD_URL=
